# remindy environment configuration
# Copy to .env and fill in. Never commit real secrets.

# --- Supermemory Local (on-machine memory + vector store) ---
# Runs single-tenant on http://localhost:6767 and prints an API key on first boot.
# Supermemory Local is a Unix binary; on Windows run it inside WSL2.
SUPERMEMORY_API_URL=http://localhost:6767
# Printed by the server on first boot. Leave empty to run fully offline (in-memory store).
SUPERMEMORY_API_KEY=

# --- Compression LLM (turns a correction into a caveman rule) ---
# Which provider remindy uses for compression. One of: ollama | openai | anthropic | bai.
# All are OpenAI-compatible, so one client covers them all. Set the key + model.
LLM_PROVIDER=ollama

# Ollama endpoint (OpenAI-compatible base becomes ${OLLAMA_URL}/v1; api key is ignored).
# This is the default, fully-local path. Nothing leaves the machine.
OLLAMA_URL=http://localhost:11434
OLLAMA_MODEL=qwen2.5-coder:3b

# OpenAI cloud. Only used when LLM_PROVIDER=openai. Base URL defaults to api.openai.com/v1.
# OPENAI_API_URL=https://api.openai.com/v1
# OPENAI_API_KEY=sk-...
# OPENAI_MODEL=gpt-5.6-luna

# Anthropic (Claude) via its OpenAI-compatible endpoint. Only used when LLM_PROVIDER=anthropic.
# ANTHROPIC_API_URL=https://api.anthropic.com/v1/
# ANTHROPIC_API_KEY=sk-ant-...
# ANTHROPIC_MODEL=claude-haiku-4-5

# b.ai cloud (OpenAI-compatible). Optional, paid. Only used when LLM_PROVIDER=bai.
# BAI_API_URL=https://api.b.ai/v1
# BAI_API_KEY=your_b_ai_api_key_here
# BAI_MODEL=claude-sonnet-5

# --- Notes on Supermemory Local's internal memory agent ---
# Supermemory runs its own LLM "memory agent" during ingestion (configured in its own
# env, not here). remindy does NOT use its output, recall ranks locally over the stored
# rules, so any model works, and a failure is harmless. Point it at local Ollama to stay
# fully on-machine (free), or at b.ai claude-sonnet-5 for clean, fast extraction.
# Note: Gemini models were tested and do NOT work with the self-hosted memory agent.

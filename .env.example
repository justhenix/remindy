# remind environment configuration (Phase 2)
# These placeholders describe the real backends that Phase 2 wires up.
# Copy to .env and fill in. Never commit real secrets.

# --- Supermemory Local (on-machine memory + vector store) ---
# Runs single-tenant on http://localhost:6767 and prints an API key on first boot.
SUPERMEMORY_API_URL=http://localhost:6767
# Printed by `npx supermemory local` on first boot. Leave empty to run fully offline (in-memory store).
SUPERMEMORY_API_KEY=

# --- LLM routing ---
# Which provider compresses corrections into caveman rules. One of: gemini | bai | ollama | openai.
LLM_PROVIDER=gemini

# Ollama endpoint (OpenAI-compatible base becomes ${OLLAMA_URL}/v1; api key is ignored).
OLLAMA_URL=http://localhost:11434
# Local model used for compression (e.g. qwen3.6, qwen2.5-coder:3b)
OLLAMA_MODEL=qwen2.5-coder:3b

# --- LLM API Keys & Routing Settings ---
# Provide the API key, base URL, and model identifier for the provider you select above.

# B.ai API configuration (see https://docs.b.ai/llmservice/api/)
# BAI_API_URL=https://api.b.ai/v1
# BAI_API_KEY=your_b_ai_api_key_here
# BAI_MODEL=claude-sonnet-5

# OpenAI API configuration (see https://platform.openai.com)
# OPENAI_API_KEY=your_openai_api_key_here
# OPENAI_MODEL=gpt-5.6-luna

# Anthropic (Claude) API configuration (see https://console.anthropic.com)
# ANTHROPIC_API_KEY=your_anthropic_api_key_here
# ANTHROPIC_MODEL=claude-sonnet-5

# Google AI Studio (Gemini) API configuration (see https://aistudio.google.com)
# Gemini is OpenAI-compatible via https://generativelanguage.googleapis.com/v1beta/openai/
# GEMINI_API_KEY=your_gemini_api_key_here
# GEMINI_MODEL=gemini-3.1-flash-lite

# DeepSeek API configuration (see https://api.deepseek.com)
# DEEPSEEK_API_URL=https://api.deepseek.com
# DEEPSEEK_API_KEY=your_deepseek_api_key_here
# DEEPSEEK_MODEL=deepseek-v4-pro

# OpenRouter API configuration (see https://openrouter.ai)
# OPENROUTER_API_URL=https://openrouter.ai/api/v1
# OPENROUTER_API_KEY=your_openrouter_api_key_here
# OPENROUTER_MODEL=deepseek/deepseek-v4-pro

# --- Reasoning & Thinking Config ---
# Used for reasoning models (e.g., GPT-5.6 Sol/Terra, Claude Sonnet 5, Gemini 3.5 Flash, DeepSeek v4 Pro)

# Reasoning Effort (Common values: low, medium, high, xhigh)
# REASONING_EFFORT=high

# Thinking Token Budget (Max tokens to dedicate to thinking, e.g. for Claude/Gemini)
# THINKING_BUDGET=2048
